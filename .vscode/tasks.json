{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/lynxkite-app/web"
      },
      "isBackground": true,
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Run backend",
      "type": "shell",
      "command": "uv run lynxkite",
      "options": {
        "cwd": "${workspaceFolder}/examples"
      },
      "isBackground": true,
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
